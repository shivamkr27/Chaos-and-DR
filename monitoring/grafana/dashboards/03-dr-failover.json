{
  "title": "DR Failover",
  "uid": "chaos-dr-failover",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 0,
      "type": "text",
      "title": "About this dashboard",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 3 },
      "options": {
        "mode": "markdown",
        "content": "This region's Prometheus/Grafana run independently with no cross-region federation, so a real primary-vs-DR side-by-side view isn't possible from here — open each region's own Grafana to compare. Regional failover itself is verified via the Cloudflare Worker response headers, not Prometheus: `curl -sI https://chaos-dr-failove.shivamkumarbxr8.workers.dev/health/live` and check `X-Served-By` / `X-Failover-Active` (see README § Chaos Experiments)."
      }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "App Up (this region)",
      "gridPos": { "x": 0, "y": 3, "w": 8, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "red",   "value": null },
            { "color": "green", "value": 1 }
          ]
        },
        "mappings": [
          { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
        ]
      },
      "targets": [{
        "expr": "min(up{job='chaos-dr-app'})",
        "legendFormat": "Up"
      }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Success Rate (this region)",
      "gridPos": { "x": 8, "y": 3, "w": 8, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "red",   "value": null },
            { "color": "yellow","value": 0.99 },
            { "color": "green", "value": 0.995 }
          ]
        },
        "unit": "percentunit"
      },
      "targets": [{
        "expr": "sum(rate(http_requests_total{status=~'2..'}[5m])) / sum(rate(http_requests_total[5m]))",
        "legendFormat": "Success Rate"
      }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "P99 Latency (this region)",
      "gridPos": { "x": 16, "y": 3, "w": 8, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 0.5 },
            { "color": "red",    "value": 2 }
          ]
        },
        "unit": "s"
      },
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
        "legendFormat": "P99"
      }]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Request Success Rate Over Time (this region)",
      "description": "During a region-failure experiment, this drops to 0 when the local EC2 is stopped — RTO is measured externally via the Worker's X-Served-By header, not here.",
      "gridPos": { "x": 0, "y": 7, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "lineWidth": 2 },
          "min": 0,
          "max": 1
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~'2..'}[1m])) / sum(rate(http_requests_total[1m]))",
          "legendFormat": "Success Rate"
        },
        {
          "expr": "vector(0.995)",
          "legendFormat": "SLO (99.5%)"
        }
      ]
    }
  ]
}
