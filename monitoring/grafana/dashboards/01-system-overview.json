{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "title": "System Overview",
  "uid": "chaos-dr-overview",
  "schemaVersion": 38,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "HTTP Success Rate",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "red",   "value": null },
            { "color": "yellow","value": 0.99 },
            { "color": "green", "value": 0.995 }
          ]
        },
        "unit": "percentunit"
      },
      "targets": [{
        "expr": "sum(rate(http_requests_total{status=~'2..'}[5m])) / sum(rate(http_requests_total[5m]))",
        "legendFormat": "Success Rate"
      }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "P99 Latency",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 0.5 },
            { "color": "red",    "value": 2 }
          ]
        },
        "unit": "s"
      },
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
        "legendFormat": "P99"
      }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "App Instances Up",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "red",   "value": null },
            { "color": "yellow","value": 1 },
            { "color": "green", "value": 2 }
          ]
        }
      },
      "targets": [{
        "expr": "count(up{job='chaos-dr-app'} == 1) or vector(0)",
        "legendFormat": "Up"
      }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request Rate (req/s)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~'2..'}[1m]))",
          "legendFormat": "2xx (success)"
        },
        {
          "expr": "sum(rate(http_requests_total{status=~'5..'}[1m]))",
          "legendFormat": "5xx (errors)"
        },
        {
          "expr": "sum(rate(http_requests_total{status=~'4..'}[1m]))",
          "legendFormat": "4xx (client errors)"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Response Time Percentiles",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[2m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[2m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[2m])) by (le))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "DB Connection Pool",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 } } },
      "targets": [
        {
          "expr": "db_pool_total_connections",
          "legendFormat": "Total"
        },
        {
          "expr": "db_pool_idle_connections",
          "legendFormat": "Idle"
        },
        {
          "expr": "db_pool_waiting_count",
          "legendFormat": "Waiting"
        }
      ]
    }
  ]
}
