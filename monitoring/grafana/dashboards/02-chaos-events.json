{
  "title": "Chaos Events",
  "uid": "chaos-dr-chaos",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Error Rate During Chaos (SLO: < 5%)",
      "description": "Red line at 5% = SLO threshold. Should stay below during pod-delete and network-latency experiments.",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 0.05 }
            ]
          }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "1 - (sum(rate(http_requests_total{status=~'2..'}[5m])) / sum(rate(http_requests_total[5m])))",
          "legendFormat": "Error Rate"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "P99 Latency During Network Chaos (SLO: < 2s)",
      "description": "During network-latency experiment (300ms injected), P99 should still stay under 2s.",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99 Latency"
        },
        {
          "expr": "vector(2)",
          "legendFormat": "SLO Threshold (2s)"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "App Process CPU Usage During CPU Stress",
      "description": "Node process CPU time from prom-client default metrics — proxy for HPA scale-up triggers now that kube-state-metrics/cAdvisor aren't scraped (see chaos/slos.yaml: HPA replica count is checked manually via 'kubectl get hpa' during cpu-stress).",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(process_cpu_seconds_total{job='chaos-dr-app'}[1m])) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ]
    }
  ]
}
